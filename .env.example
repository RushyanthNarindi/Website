# Frontend (optional when API is hosted on a different domain)
VITE_CONTACT_API_URL=

# Server-side (required for api/contact.js)
RESEND_API_KEY=
PORTFOLIO_FROM_EMAIL=
PORTFOLIO_TO_EMAIL=

# Optional CORS allow-list (comma-separated origins)
# Example: https://rushyanthnarindi.github.io,https://yourdomain.com
CONTACT_ALLOWED_ORIGINS=

# Frontend (optional when API is hosted on a different domain)
VITE_CHAT_API_URL=

# Server-side AI (required for api/chat.js)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional assistant behavior customization
OPENAI_SYSTEM_PROMPT=

# Optional CORS allow-list specific to chat endpoint
# Falls back to CONTACT_ALLOWED_ORIGINS if empty
AI_ALLOWED_ORIGINS=
